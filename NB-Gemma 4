def authenticate_huggingface() -> bool:
    """
    Load HF_TOKEN from Kaggle Secrets (never hardcoded).
    Falls back to environment variable for local development.
    Returns True on success, False if token is unavailable.
    """
    token = None

    # --- Kaggle Secrets (preferred in competition notebooks) ---
    try:
        from kaggle_secrets import UserSecretsClient  # available on Kaggle only
        token = UserSecretsClient().get_secret("HF_TOKEN")
        print(" Token loaded from Kaggle Secrets.")
    except Exception:
        pass

    # --- Environment variable fallback ---
    if not token:
        token = os.environ.get("HF_TOKEN", "")
        if token:
            print(" Token loaded from environment variable.")

    if not token:
        print(
            "   No HF_TOKEN found.\n"
            "   On Kaggle: Add-ons → Secrets → New Secret → Name: HF_TOKEN\n"
            "   Locally  : export HF_TOKEN=<your_token>"
        )
        return False

    hf_login(token=token, add_to_git_credential=False)
    print(" HuggingFace authentication successful.")
    return True


