def get_free_vram_gb() -> float:
    """Return free VRAM in GB, or 0 if no CUDA GPU is available."""
    if not torch.cuda.is_available():
        return 0.0
    free_bytes, _ = torch.cuda.mem_get_info(0)
    return free_bytes / (1024 ** 3)


def select_model() -> tuple[str, str, Optional[BitsAndBytesConfig]]:
    """
    Auto-select the best Gemma 4 model variant based on available VRAM.

    Returns:
        (model_id, description, quantisation_config)
    """
    free_gb = get_free_vram_gb()
    print(f" CUDA available : {torch.cuda.is_available()}")
    if torch.cuda.is_available():
        gpu_name = torch.cuda.get_device_name(0)
        total_gb = torch.cuda.get_device_properties(0).total_memory / (1024 ** 3)
        print(f"    GPU           : {gpu_name}")
        print(f"    Total VRAM    : {total_gb:.1f} GB")
        print(f"    Free VRAM     : {free_gb:.1f} GB")

    # bnb_4bit — loads 26B MoE safely on 16 GB T4
    bnb_4bit = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_compute_dtype=torch.bfloat16,
        bnb_4bit_use_double_quant=True,
    )

    if free_gb >= 14:
        return (
            "google/gemma-4-26b-a4b-it",
            "Gemma 4 26B MoE (4-bit) — near-frontier quality on T4 ",
            bnb_4bit,
        )
    elif free_gb >= 7:
        return (
            "google/gemma-4-e4b-it",
            "Gemma 4 E4B — balanced quality for mid-range GPUs",
            None,
        )
    else:
        return (
            "google/gemma-4-e2b-it",
            "Gemma 4 E2B — efficient edge model (CPU/low-VRAM)",
            None,
        )


