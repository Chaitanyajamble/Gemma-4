def function_calling_health_agent(query: str) -> dict:
    """
    Demonstrates Gemma 4's native JSON function-calling capability.
    Returns a structured JSON response that could invoke real health APIs.
    Showcases: Innovation criterion — non-obvious Gemma 4 feature usage.
    """
    prompt = textwrap.dedent(f"""
        You are a health information agent with access to the following tools:
        
        Tools available (respond ONLY with valid JSON, no other text):
        1. search_symptom_database(symptoms: list[str]) → returns matching conditions
        2. lookup_medication(name: str, language: str) → returns drug information
        3. find_nearby_clinic(location: str, urgency: str) → returns clinic list
        4. translate_health_content(text: str, target_language: str) → returns translation
        
        User query: "{query}"
        
        Respond with a JSON object:
        {{
          "selected_tool": "<tool_name>",
          "parameters": {{}},
          "reasoning": "<one sentence explaining why this tool was chosen>",
          "urgency": "low|medium|high|emergency"
        }}
        
        Respond ONLY with the JSON object. No preamble, no markdown fences.
    """).strip()

    raw = generate(prompt, max_new_tokens=200)

    # Safely parse JSON — strip any accidental markdown fences
    clean = raw.strip().lstrip("```json").lstrip("```").rstrip("```").strip()
    try:
        return json.loads(clean)
    except json.JSONDecodeError:
        return {
            "selected_tool": "parse_error",
            "parameters": {},
            "reasoning": "Model output could not be parsed as JSON.",
            "raw_output": raw,
            "urgency": "low",
        }

