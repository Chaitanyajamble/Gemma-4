def print_section(title: str, width: int = 72):
    bar = "─" * width
    print(f"\n{bar}")
    print(f"  {title}")
    print(bar)


def wrap_output(text: str, width: int = 72) -> str:
    lines = text.split("\n")
    wrapped = []
    for line in lines:
        if len(line) <= width:
            wrapped.append(line)
        else:
            wrapped.extend(textwrap.wrap(line, width=width))
    return "\n".join(wrapped)


