FALLBACK_MODELS = [
    "google/gemma-4-26b-a4b-it",
    "google/gemma-4-e4b-it",
    "google/gemma-4-e2b-it",
]

def free_memory():
    """Release GPU memory aggressively."""
    gc.collect()
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
        torch.cuda.synchronize()


def load_model_with_fallback(
    primary_model_id: str,
    bnb_config: Optional[BitsAndBytesConfig],
) -> tuple:
    """
    Attempt to load *primary_model_id*; fall back through FALLBACK_MODELS
    on OutOfMemoryError.

    ValueError("gemma4 not recognised") means the transformers source install
    in has NOT taken effect — the kernel must be restarted.
    We detect this and abort with a clear message instead of silently failing.

    Returns (model, processor, loaded_model_id).
    """
    candidates = [primary_model_id] + [
        m for m in FALLBACK_MODELS if m != primary_model_id
    ]

    for attempt, mid in enumerate(candidates):
        device_map = "auto" if torch.cuda.is_available() else "cpu"
        dtype      = torch.bfloat16 if torch.cuda.is_available() else torch.float32
        q_cfg      = bnb_config if (attempt == 0 and bnb_config) else None

        print(f"\n Loading {mid} (attempt {attempt + 1}/{len(candidates)}) …")
        try:
            processor = AutoProcessor.from_pretrained(
                mid, trust_remote_code=True
            )
            model = AutoModelForImageTextToText.from_pretrained(
                mid,
                device_map=device_map,
                torch_dtype=dtype,
                quantization_config=q_cfg,
                low_cpu_mem_usage=True,
                trust_remote_code=True,
            )
            model.eval()
            print(f" Model loaded: {mid}")
            return model, processor, mid

        except torch.cuda.OutOfMemoryError:
            print(f"  OOM on {mid}. Freeing memory and trying next fallback …")
            free_memory()

        except (ValueError, KeyError) as exc:
            err_str = str(exc)
            if "gemma4" in err_str.lower() or "does not recognize" in err_str.lower():
                print(
                    "\n" + "=" * 70 + "\n"
                    "    KERNEL RESTART REQUIRED\n"
                    "  The transformers package was updated in CELL 1 but the\n"
                    "  old version is still loaded in memory.\n\n"
                    "   Go to:  Runtime → Restart Session  (or Restart Kernel)\n"
                    "      Then re-run ALL cells from the top.\n"
                    "      You only need to do this ONCE per Kaggle session.\n"
                    + "=" * 70
                )
                raise SystemExit(
                    "Restart kernel and re-run — see message above."
                ) from exc
            else:
                print(f" Failed to load {mid}: {exc}")
                free_memory()

        except Exception as exc:
            print(f" Failed to load {mid}: {exc}")
            free_memory()

    # Last resort: CPU with smallest model
    print("\n  Falling back to E2B on CPU (no GPU) …")
    mid = "google/gemma-4-e2b-it"
    processor = AutoProcessor.from_pretrained(mid, trust_remote_code=True)
    model = AutoModelForImageTextToText.from_pretrained(
        mid,
        device_map="cpu",
        torch_dtype=torch.float32,
        low_cpu_mem_usage=True,
        trust_remote_code=True,
    )
    model.eval()
    print(f" Model loaded on CPU: {mid}")
    return model, processor, mid


model, processor, active_model_id = load_model_with_fallback(MODEL_ID, BNB_CONFIG)

