def symptom_triage(symptoms: str, patient_context: str = "", language: str = "English") -> str:
    """
    Triage a patient's symptoms and recommend next steps.
    Uses Gemma 4's thinking mode for complex multi-symptom cases.
    """
    prompt = textwrap.dedent(f"""
        A community health worker is reporting the following patient information.

        SYMPTOMS: {symptoms}
        PATIENT CONTEXT: {patient_context if patient_context else "Not provided."}

        Please:
        1. List the most likely conditions (top 3, ranked by probability).
        2. Identify any RED FLAG symptoms requiring immediate emergency care.
        3. Suggest safe first-aid or home care steps while awaiting professional help.
        4. Recommend the appropriate level of care: home management / clinic visit / emergency room.
        5. List questions the health worker should ask the patient to refine the assessment.
    """).strip()

    # Use thinking mode when symptoms are complex (multiple symptoms listed)
    use_thinking = len(symptoms.split(",")) >= 3 or len(symptoms.split()) >= 15
    return generate(prompt, use_thinking=use_thinking, language=language)


def explain_medication(
    medication_name: str, language: str = "English", reading_level: str = "simple"
) -> str:
    """
    Explain a medication in plain language for patients with low health literacy.
    Supports 140+ languages (Gemma 4 native).
    """
    prompt = textwrap.dedent(f"""
        Explain the medication "{medication_name}" to a patient who has never heard of it.
        Reading level: {reading_level} (use short sentences; avoid medical jargon).

        Cover:
        • What this medicine does (in one sentence).
        • How and when to take it.
        • Common side effects to watch for.
        • What NOT to do while taking it (foods, other medicines, activities).
        • When to stop and see a doctor immediately.

        Format the response as a simple, numbered list a community health worker can read aloud.
    """).strip()
    return generate(prompt, max_new_tokens=400, language=language)


